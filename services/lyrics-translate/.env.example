# Same Gemini key as lyrics-search (free tier is fine). https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional (defaults shown)
GEMINI_MODEL=gemini-2.0-flash
TRANSLATE_TARGET_LANG=en
TRANSLATED_MAX_LINES=6
# Comma-separated UI origins allowed to call this API (CORS)
ALLOWED_ORIGINS=http://localhost:3001,http://127.0.0.1:3001
