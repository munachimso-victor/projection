# Caddy front door for the projection app (single VM).
#
# One origin serves everything, so the UI uses same-origin paths and there is no
# CORS or mixed-content to manage:
#   /            -> static UI (tools/lyrics_operator/ui)
#   /api/*       -> lyrics-search   (127.0.0.1:8000)  [prefix stripped]
#   /translate/* -> lyrics-translate (127.0.0.1:8100) [prefix stripped]
#
# Site address options (pick ONE — see the first line of the block below):
#   :80                          -> HTTP only on the bare IP (http://159.65.231.252/). Simplest.
#   159.65.231.252.nip.io        -> free auto-HTTPS, no DNS setup (nip.io maps to your IP)
#   yourname.duckdns.org         -> free auto-HTTPS via DuckDNS
#   app.yourchurch.org           -> your own domain (A record -> 159.65.231.252)
#
# After editing: sudo systemctl reload caddy   (or: sudo caddy reload --config /etc/caddy/Caddyfile)

:80 {
    encode gzip

    handle_path /api/* {
        reverse_proxy 127.0.0.1:8000
    }

    handle_path /translate/* {
        reverse_proxy 127.0.0.1:8100
    }

    handle {
        root * /opt/projection/tools/lyrics_operator/ui
        file_server
    }
}
